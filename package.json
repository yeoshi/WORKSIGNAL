{
  "name": "worksignal",
  "version": "0.1.0",
  "private": true,
  "description": "WORKSIGNAL — AI-powered multi-agent job search platform for early-career Singaporeans",
  "workspaces": [
    "shared",
    "backend",
    "infra",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.19.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
