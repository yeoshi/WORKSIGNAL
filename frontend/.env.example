# Vercel AI Gateway — used by AI SDK for cover letter / resume / tailoring generation.
# Create a key at https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL_ID=anthropic/claude-sonnet-4.6

# Fallback when AI_GATEWAY_API_KEY is not set (direct AWS Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
